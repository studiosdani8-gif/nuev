 function showToastMessage(msg, icon = "fa-regular fa-circle-check") {
                    toast.innerHTML = `<i class="${icon}"></i> <span>${msg}</span>`;
                    toast.classList.add('active');
                    setTimeout(() => toast.classList.remove('active'), 2000);
                }
            
                function loadMovieUI() {
                    backdropImg.src = movieData.backdrop;
                    posterImg.src = movieData.poster;
                    movieTitleSpan.innerText = movieData.title;
                    metaDetails.innerHTML = `<span><i class="fa-regular fa-calendar"></i> ${movieData.year}</span> <span><i class="fa-regular fa-star"></i> 8.7</span> <span><i class="fa-regular fa-clock"></i> 2h 46min</span>`;
                    genresContainer.innerHTML = movieData.genres.map(g => `<span class="genre-tag">${g}</span>`).join('');
                    sinopsisTextEl.innerText = movieData.sinopsis;
                    sinopsisTextEl.style.webkitLineClamp = '3';
                    sinopsisTextEl.style.display = '-webkit-box';
                    
                    expandBtn.onclick = () => {
                        if (sinopsisTextEl.style.webkitLineClamp === '3') {
                            sinopsisTextEl.style.webkitLineClamp = 'unset';
                            sinopsisTextEl.style.display = 'block';
                            expandBtn.innerHTML = 'Mostrar menos <i class="fa-solid fa-chevron-up"></i>';
                        } else {
                            sinopsisTextEl.style.webkitLineClamp = '3';
                            sinopsisTextEl.style.display = '-webkit-box';
                            expandBtn.innerHTML = 'Mostrar más <i class="fa-solid fa-chevron-down"></i>';
                        }
                    };
                }
            
                function openServersModal() {
                    renderServersList();
                    serversModal.classList.add('active');
                    modalBackdrop.classList.add('active');
                    document.body.style.overflow = 'hidden';
                }
            
                function closeServersModal() {
                    serversModal.classList.remove('active');
                    modalBackdrop.classList.remove('active');
                    document.body.style.overflow = '';
                }
            
                function renderServersList() {
                    serversListContainer.innerHTML = '';
                    currentServers.forEach(server => {
                        const btn = document.createElement('div');
                        btn.className = 'server-option';
                        btn.innerHTML = `<i class="fa-solid fa-server"></i> ${server.title}`;
                        btn.onclick = () => {
                            closeServersModal();
                            launchFullscreenPlayer(server);
                        };
                        serversListContainer.appendChild(btn);
                    });
                }
            
                function launchFullscreenPlayer(server) {
                    currentSelectedServer = server;
                    playerStatus.innerText = `${server.title}`;
                    videoFrame.src = server.url;
                    fullscreenPlayer.classList.add('active');
                    playerLoader.style.display = 'flex';
                    
                    videoFrame.onload = () => {
                        playerLoader.style.display = 'none';
                        showToastMessage(`Reproduciendo: ${server.title}`, "fa-solid fa-play");
                    };
